{
  "name": "userflow-mcp",
  "version": "0.1.0",
  "mcpName": "io.github.prembobby39-gif/userflow-mcp",
  "description": "UserFlow MCP — Simulates real users navigating your app with different personas and delivers qualitative UX feedback. Free for Pro plan users.",
  "type": "module",
  "main": "dist/index.js",
