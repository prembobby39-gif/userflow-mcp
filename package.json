    "usability-testing",
    "puppeteer",
    "developer-tools",
    "ux-review",
    "friction-detection",
    "onboarding-testing",
    "cognitive-load",
    "user-experience",
    "synthetic-users",
    "flow-analysis",
    "userflow"
  ],
  "homepage": "https://github.com/prembobby39-gif/userflow-mcp",
  "bugs": {
    "url": "https://github.com/prembobby39-gif/userflow-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prembobby39-gif/userflow-mcp.git"
  },
